# Copy values into ~/.cursor/mcp-secrets.env (loaded by sportscience.sh).
# Only set keys for sources you use.

# export CORE_API_KEY=...
# export DIMENSIONS_API_KEY=...
# export SEMANTIC_SCHOLAR_API_KEY=...
# export KAGGLE_USERNAME=...
# export KAGGLE_KEY=...
# export MENDELEY_ACCESS_TOKEN=...

# Institutional SPORTDiscus (EBSCO EDS — from your university library)
# export EBSCO_USER_ID=...
# export EBSCO_PASSWORD=...
# export EBSCO_PROFILE=eds

# TranscriptMCP path (optional — defaults to ../TranscriptMCP)
# export TRANSCRIPT_MCP_PATH=/path/to/TranscriptMCP
